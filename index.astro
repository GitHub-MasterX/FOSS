---
// src/pages/index.astro
// The Brand New Gateway Homepage for FOSS.cloud
const communityName = "FOSS.cloud";
const currentYear = new Date().getFullYear();
import Navbar from "../components/navbar.astro";
import '../components/index.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Welcome to {communityName} | Open Source Hub</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Space+Mono&display=swap" rel="stylesheet">
	</head>
	<body>

	<Navbar /> 

		<main class="home">
			<div class="glow-effect"></div>
			
			<section class="Introduction">
				
				<h1 class="badge"> <i>Building the Open Source Culture in Trichy</i></h1>
				<h1 class="subtitle">
					FOSS Club at SRM Institute of Science & Technology, Trichy is a student-driven open-source community focused 
					on collaboration, innovation, and real-world development through technology and community-driven 
					learning.
				</h1>

				<h2>What is FOSS ?</h2>
				<p class="subtitle">
					Free and Open Source Software (FOSS) represents a culture of collaboration, 
					transparency, and innovation where technology is built collectively and shared
					openly. Our club aims to introduce students to the power of open-source development 
					by creating opportunities to learn, contribute, and grow through real-world technical
					experiences.
				</p>
				
				<h2>Why FOSS matters ?</h2>
				<p class="subtitle">
					Free and Open Source Software (FOSS) represents a culture of collaboration, 
					transparency, and innovation where technology is built collectively and shared
					openly. Our club aims to introduce students to the power of open-source development 
					by creating opportunities to learn, contribute, and grow through real-world technical
					experiences.
				</p>

				<h2>Vision -</h2>
				<p class="subtitle">
					To establish a strong and sustainable open-source ecosystem in Trichy by empowering students 
					with real-world technical exposure and collaborative development practices.
				</p>

				<h2>Mision -</h2>
				<p class="subtitle">
					Promote open-source awareness and contribution culture<br>
					Encourage collaborative learning and innovation<br>
					Create opportunities for practical technical growth<br>
					Connect students with real-world developer communities<br>
		
				</p>

				<div class="cta-group">
					<span class="mono-text"> Connect us on - </span>
					<a href="https://discord.gg/dWpp83mW3" target="_blank" rel="noopener noreferrer"> 
						<img class="connect" src="../../discord.jpg">
					</a>
					<a href="https://github" target="_blank" rel="noopener noreferrer"> 
						<img class="connect" src="../../github.jpg">
					</a>
					<a href="https://whatsapp" target="_blank" rel="noopener noreferrer"> 
						<img class="connect" src="../../whatsapp.jpg">
					</a>
				</div>
			</section>

			<section class="features-grid">
				<div class="card">
					<div class="card-icon">⚡</div>
					<h3>Lightning Fast</h3>
					<p>Zero unnecessary client-side JavaScript means our pages render in milliseconds.</p>
				</div>
				<div class="card">
					<div class="card-icon">🌐</div>
					<h3>Community First</h3>
					<p>Entirely open-source, built by students, run by volunteers, governed by code.</p>
				</div>
				<div class="card">
					<div class="card-icon">🛠️</div>
					<h3>Hands-on Tech</h3>
					<p>From core git workflows to deploying worldwide across cloud infrastructure networks.</p>
				</div>
			</section>
		</main>

		<footer class="footer">
			<p>&copy; {currentYear} {communityName}. Built with Astro OSS.</p>
		</footer>

	</body>
</html>